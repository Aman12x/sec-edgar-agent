# ── Secrets — NEVER commit ────────────────────────────────────────
.env
*.env
.env.local
.env.*.local

# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Runtime data (large, not for version control) ─────────────────
data/filings/
data/output/
data/archive/
data/checkpoints/
!data/filings/.gitkeep
!data/output/.gitkeep
!data/archive/.gitkeep
!data/checkpoints/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────
logs/
!logs/.gitkeep
*.log
*.log.zip

# ── Testing / coverage ────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/

# ── IDE ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Jupyter ───────────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# ── LLM debug outputs ─────────────────────────────────────────────
data/output/debug/

# ── SQLite databases ───────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Python version managers ────────────────────────────────────────
.python-version
