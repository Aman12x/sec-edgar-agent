# ─────────────────────────────────────────────────────────────────
# AFIP — Environment Configuration
# Usage: cp .env.example .env  then fill in REQUIRED values below
# ─────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────
# REQUIRED — get a free key at https://console.groq.com
GROQ_API_KEY=

# Switch to "ollama" for fully local inference (no API key needed)
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Only needed if LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434

# ── SEC EDGAR ─────────────────────────────────────────────────────
# REQUIRED — SEC blocks requests without a real contact.
# Format: "Firstname Lastname email@domain.com"
SEC_USER_AGENT=
SEC_RATE_LIMIT_PER_SECOND=10
SEC_MAX_CONCURRENT=10

# ── Storage ───────────────────────────────────────────────────────
STORAGE_DIR=./data/filings
OUTPUT_DIR=./data/output
ARCHIVE_DIR=./data/archive
CHECKPOINT_DB=./data/checkpoints/pipeline.db
LOG_DIR=./logs

# ── Pipeline Behaviour ────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.85
MAX_RETRY_LOOPS=3
MAX_ITEM8_CHARS=60000
MAX_ITEM1A_CHARS=15000

# ── Prefect Scheduling ────────────────────────────────────────────
# Cron: Mon-Fri at 17:00 ET (post-NYSE market close)
PREFECT_SCHEDULE=0 17 * * 1-5
PREFECT_TIMEZONE=America/New_York
PREFECT_MAX_CONCURRENT_TICKERS=5
# Leave blank for local runs — only needed for Prefect Cloud
PREFECT_API_KEY=

# ── LangSmith Tracing (optional) ─────────────────────────────────
# Get a free key at https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=afip
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Feature Flags ─────────────────────────────────────────────────
DRY_RUN=false
SAVE_LLM_RAW_RESPONSE=false
ARCHIVE_AFTER_PROCESSING=false
